{
  "name": "gershon-crm-dashboard",
  "version": "1.1.11",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev dist --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "start": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true"
  },
  "dependencies": {
    "hono": "^4.11.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "vite": "^6.3.5",
    "wrangler": "^3.87.0"
  }
}
